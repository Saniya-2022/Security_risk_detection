# MongoDB Atlas Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/security_risk_detection

# Email Configuration (Gmail)
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-gmail-app-password

# Notes:
# 1. Replace 'username' and 'password' in MONGO_URI with your MongoDB Atlas credentials
# 2. For Gmail, use an App Password (not your regular password)
#    Generate one at: https://myaccount.google.com/apppasswords
# 3. Copy this file to .env and fill in your actual credentials
